[internationalization]

locale/translations=PackedStringArray("res://localization/strings.en.translation", "res://localization/strings.de.translation", "res://localization/strings.fr.translation", "res://localization/strings.es.translation", "res://localization/strings.it.translation", "res://localization/strings.pt_BR.translation", "res://localization/strings.pl.translation", "res://localization/strings.ru.translation", "res://localization/strings.tr.translation", "res://localization/strings.ja.translation", "res://localization/strings.zh_CN.translation", "res://localization/strings.ko.translation")
